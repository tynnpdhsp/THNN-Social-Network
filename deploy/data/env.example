# Copy to .env next to docker-compose.yml on the server:
#   cp env.example .env && nano .env

# MongoDB root (use in server/.env MONGO_DATABASE_URL)
MONGO_ROOT_USER=thnn_admin
MONGO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis AUTH
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# MinIO root credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# --- Bootstrap admin (bootstrap_defaults.sh; lần đầu + sau reset DB) ---
# Mật khẩu mặc định khi KHÔNG set BOOTSTRAP_ADMIN_PASSWORD_HASH: ChangeMeAdmin123!
# (bcrypt passlib/bcrypt 3.2 — khớp backend). Đổi mật khẩu ngay sau đăng nhập production.
BOOTSTRAP_ADMIN_EMAIL=admin@thnn.com
BOOTSTRAP_ADMIN_PHONE=0888999000
BOOTSTRAP_ADMIN_FULL_NAME=Quản trị viên hệ thống
# BOOTSTRAP_ADMIN_PASSWORD_HASH='$2b$12$...'   # tùy chọn: ghi đè hash (đặt trong .env thật, không commit)
