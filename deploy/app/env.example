# Copy to .env in /opt/social-app/app before first deploy.

# --- Backend app ---
APP_NAME=THNN Social Network
APP_VERSION=1.0.0
DEBUG=false
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["https://social.hcmue.info.vn"]

# --- Data services on Docker network social_data ---
MONGO_DATABASE_URL=mongodb://thnn_admin:CHANGE_ME_STRONG_PASSWORD@mongodb:27017/thnn_social_network?authSource=admin&replicaSet=rs0
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# --- Security ---
JWT_SECRET_KEY=CHANGE_ME_SUPER_SECRET_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- OTP ---
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_LENGTH=6

# --- Email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# --- MinIO ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET=thnn
MINIO_SECURE=false

# --- Rate limiting ---
LOGIN_RATE_LIMIT_IP=10
LOGIN_RATE_LIMIT_EMAIL=5
LOGIN_RATE_LIMIT_IP_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_EMAIL_WINDOW_SECONDS=1800

# --- Upload ---
MAX_AVATAR_SIZE_MB=5
MAX_COVER_SIZE_MB=10
MAX_BIO_LENGTH=500

# --- VNPay sandbox ---
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=
VNPAY_RETURN_URL=
VNPAY_HASH_SECRET=

# --- Frontend build args ---
# Keep same-origin API via reverse proxy.
VITE_API_BASE=/api/v1
VITE_WS_BASE=
VITE_MINIO_PUBLIC_URL=https://social.hcmue.info.vn/storage
