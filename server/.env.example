# =============================================================================
# ENVIRONMENT VARIABLES — Mạng Xã Hội Sinh Viên
# Copy file này thành .env và điền giá trị thực tế
# =============================================================================

# App
APP_NAME="THNN Social Network"
APP_VERSION="1.0.0"
DEBUG=true
API_V1_PREFIX="/api/v1"

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# MongoDB Connection (Prisma)
MONGO_DATABASE_URL="mongodb://username:password@localhost:27017/thnn_social_network?authSource=admin"

# Redis
REDIS_URL="redis://localhost:6379/0"

# JWT
JWT_SECRET_KEY="your-super-secret-key-change-me"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# OTP
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_LENGTH=6

# Email (SMTP Gmail)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="your-email@gmail.com"

# MinIO
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="minio-access-key"
MINIO_SECRET_KEY="minio-secret-key"
MINIO_BUCKET="thnn"
MINIO_SECURE=false

# Rate Limiting
LOGIN_RATE_LIMIT_IP=10
LOGIN_RATE_LIMIT_EMAIL=5
LOGIN_RATE_LIMIT_IP_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_EMAIL_WINDOW_SECONDS=1800

# Upload
MAX_AVATAR_SIZE_MB=5
MAX_COVER_SIZE_MB=10
MAX_BIO_LENGTH=500

# VNPay
VNPAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNPAY_TMN_CODE=
# url của fe - vnpay redirect sau khi thanh toán xong (đã thanh toán, hủy thanh toán)
VNPAY_RETURN_URL=
VNPAY_HASH_SECRET=