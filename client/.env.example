# Bản build / chạy production: copy thành .env.production hoặc .env.local và chỉnh giá trị public.
# Không đặt secret backend vào đây — chỉ URL mà trình duyệt gọi được.

# API REST — full URL dev, hoặc path tương đối khi chỉ public frontend qua reverse proxy (cùng domain):
#   VITE_API_BASE=/api/v1
VITE_API_BASE=http://localhost:8000/api/v1

# WebSocket — để trống sẽ suy ra: http/https URL → ws/wss; path /api/v1 → wss://<host hiện tại>/api/v1
# VITE_WS_BASE=ws://localhost:8000/api/v1

# Ảnh MinIO — nếu proxy /storage → MinIO thì ví dụ VITE_MINIO_PUBLIC_URL=https://your-domain.com/storage
VITE_MINIO_PUBLIC_URL=http://localhost:9000
